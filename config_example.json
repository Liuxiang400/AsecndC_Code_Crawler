{
  "max_repos": 20,
  "max_files_per_repo": 200,
  "min_stars": 5,
  "min_forks": 2,
  "days_since_update": 180,
  "file_extensions": [
    ".py",
    ".cpp",
    ".c",
    ".h",
    ".hpp",
    ".md",
    ".txt",
    ".json",
    ".yaml",
    ".yml"
  ],
  "branch": "master",
  "output_dir": "output/ascendc",
  "results_dir": "output/results",
  "search_keywords": [
    "AscendC",
    "Ascend",
    "CANN",
    "NPU算子开发"
  ],
  "search_language": null,
  "search_sort": "stars",
  "search_order": "desc",
  "request_timeout": 10,
  "retry_times": 3,
  "request_delay": 0.5,
  "log_level": "INFO",
  "log_file": "logs/ascendc_crawler.log"
}
